---
import Base from "@shared/layouts/Base.astro";
import { getCollection } from "astro:content";
import type { Locale } from "@shared/i18n/translations";
import { footerPageTitles } from "@shared/i18n/translations";
import fs from "node:fs";
import path from "node:path";
import { marked } from "marked";

const locale = Astro.locals.locale as Locale;

// Load intro markdown (from content/pages/en/evidence.md)
let introHtml = "";
const localeDir = locale === "zh-cn" ? "zh-cn" : locale;
const introPath = path.join(process.cwd(), "..", "..", "content", "pages", localeDir, "evidence.md");
try {
  const md = fs.readFileSync(introPath, "utf-8").trim();
  if (md) introHtml = await marked(md);
} catch { /* no intro */ }

// Load ALL evidence entries — no pagination (per user request)
const allEvidence = await getCollection("evidence");
const evidence = allEvidence.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const title = footerPageTitles[locale]?.["footer.evidence"] || "List of Evidence (non-exhaustive list)";

function formatDate(date: Date): string {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, "0");
  const d = String(date.getDate()).padStart(2, "0");
  return `${y}-${m}-${d}`;
}
---
<Base locale={locale} title={title}>
  <div class="page-container">
    <h1>{title}</h1>

    {introHtml && <div class="intro-content prose" set:html={introHtml} />}

    <p class="count-note">{evidence.length} entries</p>

    <div class="evidence-list">
      {evidence.map((item) => {
        const href = `/list-of-evidence/${item.data.slug}/`;
        return (
          <div class="evidence-card">
            <a href={href} class="evidence-title-link">
              <h3>{item.data.title}</h3>
            </a>
            {item.data.description && (
              <p class="evidence-desc">{item.data.description}</p>
            )}
            <p class="evidence-read-more"><a href={href}>Click here to read more.</a></p>
            <div class="evidence-meta">
              <span>{formatDate(item.data.date)}</span>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</Base>

<style>
  .page-container { max-width: 73rem; margin: 0 auto; padding: 2rem 1rem; }
  .page-container h1 { margin-bottom: 0.5em; font-size: 2.25rem; font-weight: 800; line-height: 1.1111; }
  .intro-content { margin-bottom: 2rem; line-height: 1.7; }
  .count-note { margin-bottom: 1.5rem; font-size: 0.9rem; opacity: 0.6; }
  .evidence-list { border-top: 1px solid var(--color-nav-border); }
  .evidence-card { padding: 1.5rem 0; border-bottom: 1px solid var(--color-nav-border); }
  .evidence-title-link { text-decoration: none; color: var(--color-text); }
  .evidence-title-link:hover { color: var(--color-link-hover); }
  .evidence-title-link h3 { margin: 0 0 0.5rem 0; font-size: 1.25rem; font-weight: 700; }
  .evidence-desc { margin: 0 0 0.5rem 0; line-height: 1.7; }
  .evidence-read-more { margin: 0 0 0.5rem 0; }
  .evidence-read-more a { color: var(--color-link); }
  .evidence-meta { font-size: 0.875rem; opacity: 0.6; }
</style>
