---
import Base from "@shared/layouts/Base.astro";
import { getCollection, render } from "astro:content";
import type { Locale } from "@shared/i18n/translations";
import fs from "node:fs";
import path from "node:path";
import { marked } from "marked";

const locale = Astro.locals.locale as Locale;

// Load the intro content from markdown
let introHtml = "";
const localeDir = locale === "zh-cn" ? "zh-cn" : locale;
const casesPath = path.join(process.cwd(), "..", "..", "content", "pages", localeDir, "cases.md");
try {
  const md = fs.readFileSync(casesPath, "utf-8").trim();
  if (md) introHtml = await marked(md);
} catch { /* no intro content */ }

// Get all cases
const allCases = await getCollection("cases");
const cases = allCases.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(date: Date): string {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, "0");
  const d = String(date.getDate()).padStart(2, "0");
  return `${y}-${m}-${d}`;
}
---
<Base locale={locale}>
  <div class="page-container">
    <h1>List of cases submitted to the European Court of Human Rights</h1>

    {introHtml && <div class="intro-content prose" set:html={introHtml} />}

    <div class="cases-list">
      {cases.map((c) => {
        const href = `/cases/${c.data.slug}/`;
        return (
          <div class="case-card">
            <a href={href} class="case-title-link">
              <h3>{c.data.title}</h3>
            </a>
            {c.data.description && <p class="case-desc">{c.data.description}</p>}
            <p class="case-read-more"><a href={href}>Click here to read more.</a></p>
            <div class="case-meta">
              <span class="meta-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                {formatDate(c.data.date)}
              </span>
              <span class="meta-item">1 min read</span>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</Base>

<style>
  .page-container { max-width: 73rem; margin: 0 auto; padding: 2rem 1rem; }
  .page-container h1 { margin-bottom: 1.5rem; font-size: 1.8rem; line-height: 1.3; }
  .intro-content { margin-bottom: 2rem; line-height: 1.7; }
  .cases-list { border-top: 1px solid var(--color-nav-border); }
  .case-card { padding: 1.5rem 0; border-bottom: 1px solid var(--color-nav-border); }
  .case-title-link { text-decoration: none; color: var(--color-text); }
  .case-title-link:hover { color: var(--color-link-hover); }
  .case-title-link h3 { margin: 0 0 0.5rem 0; font-size: 1.25rem; font-weight: 700; }
  .case-desc { margin: 0 0 0.5rem 0; line-height: 1.7; }
  .case-read-more { margin: 0 0 0.75rem 0; }
  .case-read-more a { color: var(--color-link); }
  .case-meta { display: flex; gap: 1.25rem; font-size: 0.875rem; color: #6b7280; }
  [data-theme="dark"] .case-meta { color: #9ca3af; }
  .meta-item { display: flex; align-items: center; gap: 0.35rem; }
</style>
