---
import Base from "@shared/layouts/Base.astro";
import type { Locale } from "@shared/i18n/translations";
import { t } from "@shared/i18n/utils";
import fs from "node:fs";
import path from "node:path";
import { marked } from "marked";

const locale = Astro.locals.locale as Locale;

// About section translations
const aboutData: Record<Locale, { title: string; role: string; bio: string; org: string; orgUrl: string }> = {
  en: {
    title: "European Court of Human Rights Watch",
    role: "Key Witness \u2022 Analyst \u2022 Whistleblower",
    bio: "I am the key witness and whistleblower in a major international criminal case targeting McDonald\u2019s Corporation for decades of mass-marketing consumer fraud and cross-border money laundering.<br/><br/>The case, registered as application 50552/22 before the European Court of Human Rights, is part of broader efforts to expose a pattern of serious misconduct affecting billions of consumers and implicating both corporate and institutional actors.",
    org: "Vincent Le Corre",
    orgUrl: "https://www.linkedin.com/in/x-v-france/",
  },
  fr: {
    title: "European Court of Human Rights Watch",
    role: "T\u00e9moin cl\u00e9 \u2022 Analyste \u2022 Lanceur d\u2019alerte",
    bio: "Je suis le t\u00e9moin cl\u00e9 et le lanceur d\u2019alerte dans une affaire p\u00e9nale internationale majeure visant McDonald\u2019s Corporation pour des d\u00e9cennies d\u2019escroqueries aggrav\u00e9es \u00e0 grande \u00e9chelle et de blanchiment d\u2019argent transfrontalier.<br/><br/>L\u2019affaire, enregistr\u00e9e sous le num\u00e9ro 50552/22 devant la Cour europ\u00e9enne des droits de l\u2019homme, s\u2019inscrit dans un effort plus large visant \u00e0 r\u00e9v\u00e9ler un ensemble de graves d\u00e9lits et crimes touchant des milliards de consommateurs et impliquant des acteurs \u00e0 la fois institutionnels et priv\u00e9s.",
    org: "Vincent Le Corre",
    orgUrl: "https://www.linkedin.com/in/x-v-france/",
  },
  it: {
    title: "European Court of Human Rights Watch",
    role: "Key Witness \u2022 Analyst \u2022 Whistleblower",
    bio: "",
    org: "Vincent Le Corre",
    orgUrl: "https://www.linkedin.com/in/x-v-france/",
  },
  "zh-cn": {
    title: "\u6b27\u6d32\u4eba\u6743\u6cd5\u9662\u89c2\u5bdf",
    role: "\u5173\u952e\u8bc1\u4eba \u2022 \u5206\u6790\u5e08 \u2022 \u4e3e\u62a5\u4eba",
    bio: "\u6211\u662f\u4e00\u8d77\u91cd\u5927\u56fd\u9645\u5211\u4e8b\u6848\u4ef6\u7684\u5173\u952e\u8bc1\u4eba\u548c\u4e3e\u62a5\u4eba\uff0c\u8be5\u6848\u4ef6\u9488\u5bf9\u9ea6\u5f53\u52b3\u516c\u53f8\u6570\u5341\u5e74\u6765\u7684\u5927\u89c4\u6a21\u6d88\u8d39\u8005\u6b3a\u8bc8\u548c\u8de8\u5883\u6d17\u94b1\u884c\u4e3a\u3002<br/><br/>\u8be5\u6848\u4ef6\u4ee5\u7533\u8bf7\u53f7 50552/22 \u5728\u6b27\u6d32\u4eba\u6743\u6cd5\u9662\u767b\u8bb0\uff0c\u662f\u63ed\u9732\u5f71\u54cd\u6570\u5341\u4ebf\u6d88\u8d39\u8005\u5e76\u6d89\u53ca\u4f01\u4e1a\u548c\u673a\u6784\u884c\u4e3a\u8005\u7684\u4e25\u91cd\u4e0d\u5f53\u884c\u4e3a\u6a21\u5f0f\u7684\u66f4\u5e7f\u6cdb\u52aa\u529b\u7684\u4e00\u90e8\u5206\u3002",
    org: "Vincent Le Corre",
    orgUrl: "https://www.linkedin.com/in/x-v-france/",
  },
};

const about = aboutData[locale] || aboutData.en;

// Load homepage executive summary markdown
let execSummaryHtml = "";
const localeDir = locale === "zh-cn" ? "zh-cn" : locale;
const homepageMd = path.join(process.cwd(), "..", "..", "content", "pages", localeDir, "homepage.md");
try {
  const md = fs.readFileSync(homepageMd, "utf-8").trim();
  if (md) {
    execSummaryHtml = await marked(md);
  }
} catch {
  // No homepage content file
}

const socialLinks = [
  { icon: "envelope", href: "mailto:vincent@ecthrwatch.org", label: "Email" },
  { icon: "linkedin", href: "https://www.linkedin.com/in/x-v-france", label: "LinkedIn" },
  { icon: "twitter", href: "https://twitter.com/ECtHRwatch", label: "Twitter" },
  { icon: "github", href: "https://github.com/ecthrwatch", label: "GitHub" },
];

const contactText: Record<Locale, { linkedin: string; email: string }> = {
  en: { linkedin: "Click here to follow me on LinkedIn", email: "You can also send me an email at this address:" },
  fr: { linkedin: "Cliquez ici pour me suivre sur LinkedIn", email: "Vous pouvez aussi m'envoyer un email \u00e0 cette adresse :" },
  it: { linkedin: "Clicca qui per seguirmi su LinkedIn", email: "Puoi anche inviarmi un'email a questo indirizzo:" },
  "zh-cn": { linkedin: "\u70b9\u51fb\u8fd9\u91cc\u5728 LinkedIn \u4e0a\u5173\u6ce8\u6211", email: "\u60a8\u4e5f\u53ef\u4ee5\u901a\u8fc7\u4ee5\u4e0b\u5730\u5740\u7ed9\u6211\u53d1\u9001\u7535\u5b50\u90ae\u4ef6\uff1a" },
};
const contact = contactText[locale] || contactText.en;
---
<Base locale={locale}>
  <div class="home-container">
    <!-- About Section -->
    <div class="about-section">
      <div class="about-header">
        <div class="about-avatar">
          <img
            src="/images/christian_cross.png"
            alt="The Christian Integrity"
            class="avatar-img"
          />
        </div>
        <div class="about-info">
          <h1>{about.title}</h1>
          <div class="about-divider"></div>
          <div class="about-role">
            <span>{about.role}</span>
            <a href={about.orgUrl}>{about.org}</a>
          </div>
          {about.bio && (
            <div class="about-bio" set:html={about.bio} />
          )}
        </div>
        <div class="about-social">
          {socialLinks.map((link) => (
            <a href={link.href} title={link.label} class="social-icon">
              {link.icon === "envelope" && "\u2709"}
              {link.icon === "linkedin" && "in"}
              {link.icon === "twitter" && "\ud835\udccd"}
              {link.icon === "github" && "\u2b21"}
            </a>
          ))}
        </div>
      </div>

      <!-- Executive Summary -->
      {execSummaryHtml && (
        <div class="exec-summary" set:html={execSummaryHtml} />
      )}

      <!-- Portrait + contact -->
      <div class="portrait-section">
        <a href="https://www.linkedin.com/in/x-v-france/">
          <img
            src="/images/vlc_portrait.jpeg"
            alt="Vincent"
            class="portrait-img"
          />
        </a>
      </div>
      <p class="contact-links">
        <a href="https://www.linkedin.com/in/x-v-france">{contact.linkedin}</a><br/>
        {contact.email} <a href="mailto:vincent@ecthrwatch.org">vincent@ecthrwatch.org</a>
      </p>
    </div>
  </div>

  <!-- Banner section above footer -->
  <div class="banner-section">
    <div class="banner-bg" style="background-image: url(/images/logos/ecthrwatch_banner_mcdonalds_227w_112h.jpg);"></div>
  </div>
</Base>

<style>
  .home-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  /* About header */
  .about-header {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .about-avatar {
    flex-shrink: 0;
    width: 180px;
  }

  .avatar-img {
    width: 100%;
    display: block;
  }

  .about-info {
    flex: 1;
  }

  .about-info h1 {
    font-size: 1.8rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .about-divider {
    width: 25%;
    border-bottom: 1px solid var(--color-nav-border);
    margin-bottom: 1rem;
  }

  .about-role {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .about-bio {
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .about-social {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    font-size: 1rem;
    text-decoration: none;
    color: var(--color-text);
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .social-icon:hover {
    opacity: 1;
    text-decoration: none;
  }

  /* Executive Summary */
  .exec-summary {
    margin-top: 1rem;
  }

  .exec-summary :global(p) {
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .exec-summary :global(strong) {
    font-weight: 700;
  }

  .exec-summary :global(em) {
    font-style: italic;
  }

  /* Portrait */
  .portrait-section {
    text-align: center;
    margin: 1.5rem 0;
  }

  .portrait-img {
    width: 128px;
    height: auto;
    border-radius: 50%;
    display: inline-block;
  }

  .contact-links {
    text-align: center;
    margin-bottom: 2rem;
    line-height: 1.8;
  }

  /* Banner section above footer */
  .banner-section {
    width: 100%;
  }

  .banner-bg {
    width: 100%;
    height: 120px;
    background-size: contain;
    background-repeat: repeat-x;
    background-position: center;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .about-header {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .about-avatar {
      width: 140px;
    }

    .about-role {
      justify-content: center;
    }

    .about-divider {
      margin-left: auto;
      margin-right: auto;
    }

    .about-social {
      flex-direction: row;
    }
  }
</style>
