---
import Base from "@shared/layouts/Base.astro";
import { getCollection, render } from "astro:content";
import type { Locale } from "@shared/i18n/translations";

export async function getStaticPaths() {
  const laws = await getCollection("laws");
  return laws.map((law) => ({
    params: { slug: law.data.slug },
    props: { law },
  }));
}

const { law } = Astro.props;
const locale = Astro.locals.locale as Locale;
const { Content } = await render(law);
---
<Base locale={locale} title={law.data.title} description={law.data.description} type="article">
  <article class="page-container">
    <h1>{law.data.title}</h1>
    <div class="law-content prose">
      <Content />
    </div>
  </article>
</Base>

<style>
  .page-container { max-width: 73rem; margin: 0 auto; padding: 2rem 1rem; }
  .page-container h1 { margin-bottom: 0.8889em; font-size: 2.25rem; font-weight: 800; line-height: 1.1111; }
  .law-content { line-height: 1.7; }
</style>
