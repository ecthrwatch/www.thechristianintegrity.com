---
import Base from "@shared/layouts/Base.astro";
import TimelineList from "@shared/components/TimelineList.astro";
import { getCollection } from "astro:content";
import { filterTimelineEvents } from "@shared/utils/timeline";
import { t } from "@shared/i18n/utils";
import type { Locale } from "@shared/i18n/translations";

const locale = Astro.locals.locale as Locale;
const siteDomain = Astro.locals.siteDomain;
const timelineShowAll = Astro.locals.timelineShowAll;

const allEvents = await getCollection("timeline");
const events = filterTimelineEvents(allEvents, siteDomain, timelineShowAll);
---
<Base locale={locale} title={t(locale, "page.timeline")}>
  <TimelineList events={events} locale={locale} />
</Base>
