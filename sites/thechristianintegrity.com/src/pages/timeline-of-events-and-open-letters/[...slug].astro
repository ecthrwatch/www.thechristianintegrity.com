---
import Base from "@shared/layouts/Base.astro";
import TimelineDetail from "@shared/components/TimelineDetail.astro";
import { getCollection, render } from "astro:content";
import type { Locale } from "@shared/i18n/translations";

export async function getStaticPaths() {
  const events = await getCollection("timeline");
  return events
    .filter((e) => !e.data.draft)
    .map((event) => ({
      params: { slug: event.data.slug },
      props: { event },
    }));
}

const { event } = Astro.props;
const locale = Astro.locals.locale as Locale;
const { Content } = await render(event);

const featImg = event.data.featuredImage;
const metaImage = featImg ? `/images/featured/${featImg.replace(/^images\//, "")}` : undefined;
---
<Base
  locale={locale}
  title={event.data.title}
  description={event.data.description}
  image={metaImage}
  type="article"
>
  <TimelineDetail event={event} locale={locale} Content={Content} />
</Base>
