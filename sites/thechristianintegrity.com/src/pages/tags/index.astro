---
import Base from "@shared/layouts/Base.astro";
import { getCollection } from "astro:content";
import { filterTimelineEvents } from "@shared/utils/timeline";
import { collectTags } from "@shared/utils/tags";
import type { Locale } from "@shared/i18n/translations";

const locale = Astro.locals.locale as Locale;
const siteDomain = Astro.locals.siteDomain;
const timelineShowAll = Astro.locals.timelineShowAll;

const allEvents = await getCollection("timeline");
const events = filterTimelineEvents(allEvents, siteDomain, timelineShowAll);
const tags = collectTags(events);
---
<Base locale={locale}>
  <div class="page-container">
    <h1>Tags</h1>
    <div class="tag-cloud">
      {tags.map((t) => (
        <a href={`/tags/${t.slug}/`} class="tag-pill">
          {t.tag}
          <span class="tag-count">{t.count}</span>
        </a>
      ))}
    </div>
  </div>
</Base>

<style>
  .page-container {
    max-width: 73rem;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .page-container h1 {
    margin-bottom: 0.8889em;
    font-size: 2.25rem;
    font-weight: 800;
    line-height: 1.1111;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.75rem;
    background: var(--color-bg);
    border: 1px solid var(--color-nav-border);
    border-radius: 9999px;
    font-size: 0.85rem;
    color: var(--color-text);
    text-decoration: none;
    transition: background-color 0.15s, border-color 0.15s;
  }

  .tag-pill:hover {
    background: var(--color-nav-border);
    text-decoration: none;
  }

  .tag-count {
    font-size: 0.75rem;
    opacity: 0.6;
  }

  [data-theme="dark"] .tag-pill {
    background: #1c1c1e;
  }

  [data-theme="dark"] .tag-pill:hover {
    background: #333;
  }
</style>
