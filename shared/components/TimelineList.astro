---
/**
 * Shared timeline listing component.
 * Renders the list of timeline event cards with featured images, date, reading time.
 * Used by all sites' timeline index pages.
 */
import type { Locale } from "../i18n/translations";
import { t } from "../i18n/utils";
import { navSlugs } from "../i18n/translations";
import { formatDate, estimateReadingTime } from "../utils/timeline";

interface Props {
  events: any[];
  locale: Locale;
}

const { events, locale } = Astro.props;
const timelineSlug = navSlugs[locale]?.["nav.timeline"] || "timeline-of-events-and-open-letters";
---
<div class="page-container">
  <h1>{t(locale, "page.timeline")}</h1>
  <div class="timeline-entries">
    {events.map((event) => {
      const slug = event.data.slug;
      const href = `/${timelineSlug}/${slug}/`;
      const readMin = estimateReadingTime(event.data.description);
      const featImg = event.data.featuredImage;
      const imgSrc = featImg ? `/images/featured/${featImg.replace(/^images\//, "")}` : null;
      return (
        <div class="timeline-card">
          <div class="card-content" data-has-image={imgSrc ? "true" : undefined}>
            <div class="card-text">
              <a href={href} class="card-title-link">
                <h3>{event.data.title}</h3>
              </a>
              <p class="card-description">
                {event.data.description}
              </p>
              <p class="card-read-more">
                <a href={href}>Click here to read more.</a>
              </p>
              <div class="card-meta">
                <span class="card-date">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                  {formatDate(event.data.date)}
                </span>
                <span class="card-reading-time">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                  {readMin} min read
                </span>
              </div>
            </div>
            {imgSrc && (
              <div class="card-image">
                <a href={href}>
                  <img src={imgSrc} alt="Featured Image" loading="lazy" />
                </a>
              </div>
            )}
          </div>
        </div>
      );
    })}
  </div>
  {events.length === 0 && <p>No events found.</p>}
</div>

<style>
  .page-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .page-container h1 {
    margin-bottom: 1.5rem;
    font-size: 1.8rem;
    line-height: 1.3;
  }

  .timeline-entries {
    border-top: 1px solid var(--color-nav-border);
  }

  .timeline-card {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-nav-border);
  }

  .card-content {
    display: flex;
    flex-direction: column-reverse;
  }

  .card-content[data-has-image] {
    flex-direction: row;
    gap: 2rem;
  }

  .card-text {
    flex: 1;
  }

  .card-title-link {
    text-decoration: none;
    color: var(--color-text);
  }

  .card-title-link:hover {
    color: var(--color-link-hover);
    text-decoration: none;
  }

  .card-title-link h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.4;
  }

  .card-description {
    margin: 0 0 0.5rem 0;
    line-height: 1.7;
    color: var(--color-text);
  }

  .card-read-more {
    margin: 0 0 0.75rem 0;
  }

  .card-read-more a {
    color: var(--color-link);
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    font-size: 0.875rem;
    color: #6b7280;
  }

  [data-theme="dark"] .card-meta {
    color: #9ca3af;
  }

  .card-date,
  .card-reading-time {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .card-image {
    flex-shrink: 0;
    width: 33.333%;
  }

  .card-image img {
    width: 100%;
    height: auto;
    border-radius: 4px;
    display: block;
  }

  @media (max-width: 768px) {
    .card-content[data-has-image] {
      flex-direction: column-reverse;
    }

    .card-image {
      width: 100%;
      margin-bottom: 1rem;
    }
  }
</style>
