---
import { t } from "../i18n/utils";
import type { Locale } from "../i18n/translations";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const name = t(locale, "footer.copyright.name");
const url = t(locale, "footer.copyright.url");

const linkKeys = [
  "home", "about", "cases", "contact", "copyright",
  "privacy", "other", "laws", "crime", "evidence",
] as const;

const links = linkKeys
  .map((key) => ({
    label: t(locale, `footer.link.${key}`),
    href: t(locale, `footer.link.${key}.href`),
  }))
  .filter((link) => link.label && link.href);
---
<footer class="footer">
  {links.length > 0 && (
    <div class="footer-links">
      {links.map((link, i) => (
        <>
          <a href={link.href}>{link.label}</a>
          {i < links.length - 1 && <span class="footer-sep"> | </span>}
        </>
      ))}
    </div>
  )}
  <div class="footer-org">{t(locale, "site.org")}</div>
  <div>&copy; 2021-{new Date().getFullYear()} <a href={url}>{name}</a></div>
</footer>
