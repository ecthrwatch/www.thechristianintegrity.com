---
import { getDict, renderInlineMarkdown } from "../data/loader";
import type { Locale } from "../i18n/translations";

interface Props {
  file: string;
  entry: string;
}

const { file, entry } = Astro.props;
const locale = Astro.locals.locale as Locale;
const value = getDict(locale, file, entry);
const html = renderInlineMarkdown(value);
---
<span set:html={html} />
