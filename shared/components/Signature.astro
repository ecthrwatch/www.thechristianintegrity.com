---
import { getSignature } from "../data/loader";
import type { Locale } from "../i18n/translations";

interface Props {
  signatureKey?: string;
}

const { signatureKey } = Astro.props;
const locale = Astro.locals.locale as Locale;
const sig = getSignature(locale, signatureKey);
---
{sig ? (
  <p>
    <a href={sig.linkedin.url}>{sig.linkedin.text}</a><br />
    {sig.email.text} <a href={`mailto:${sig.email.address}`}>{sig.email.address}</a>
  </p>
) : (
  <p><em>Signature not found</em></p>
)}
