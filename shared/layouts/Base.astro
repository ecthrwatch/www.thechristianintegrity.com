---
import { t } from "../i18n/utils";
import type { Locale } from "../i18n/translations";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import "@styles/main.css";

interface Props {
  locale: Locale;
  /** Page title — defaults to site name */
  title?: string;
  /** Meta description — used for SEO + OG/Twitter previews */
  description?: string;
  /** Absolute or site-relative URL of the preview image (used in og:image and twitter:image) */
  image?: string;
  /** Page URL type — "article" for content pages, "website" for index/listings */
  type?: "article" | "website";
}

const {
  locale,
  title: pageTitle,
  description: pageDescription,
  image: pageImage,
  type = "website",
} = Astro.props;

const siteName = Astro.locals.siteName ?? "Site";
const siteDomain = Astro.locals.siteDomain ?? "";

// Full page title: "Page Title | Site Name" or just "Site Name" on homepage
const fullTitle = pageTitle && pageTitle !== siteName ? `${pageTitle} | ${siteName}` : siteName;

// Description fallback: page-specific, then empty (can be set per-site later)
const descriptionText = pageDescription ?? "";

// Absolute URL for this page
const siteOrigin = siteDomain ? `https://www.${siteDomain}` : Astro.url.origin;
const pageUrl = new URL(Astro.url.pathname, siteOrigin).href;

// Resolve image URL to absolute
let imageAbsUrl = "";
if (pageImage) {
  if (pageImage.startsWith("http://") || pageImage.startsWith("https://")) {
    imageAbsUrl = pageImage;
  } else if (pageImage.startsWith("/")) {
    imageAbsUrl = new URL(pageImage, siteOrigin).href;
  } else {
    imageAbsUrl = new URL("/" + pageImage, siteOrigin).href;
  }
}
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;600;700&family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet" />
    <title>{fullTitle}</title>
    {descriptionText && <meta name="description" content={descriptionText} />}

    {/* Canonical URL */}
    <link rel="canonical" href={pageUrl} />

    {/* Open Graph (Facebook, LinkedIn, WhatsApp, etc.) */}
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    {descriptionText && <meta property="og:description" content={descriptionText} />}
    <meta property="og:type" content={type} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:locale" content={locale} />
    {imageAbsUrl && <meta property="og:image" content={imageAbsUrl} />}

    {/* Twitter Cards */}
    <meta name="twitter:card" content={imageAbsUrl ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={fullTitle} />
    {descriptionText && <meta name="twitter:description" content={descriptionText} />}
    {imageAbsUrl && <meta name="twitter:image" content={imageAbsUrl} />}

    <script is:inline>
      (function () {
        var pref = localStorage.getItem("theme") || "auto";
        var resolved = pref === "auto"
          ? (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light")
          : pref;
        document.documentElement.setAttribute("data-theme", resolved);
      })();
    </script>
  </head>
  <body>
    <Nav locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
